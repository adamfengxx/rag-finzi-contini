# ── OpenAI ───────────────────────────────────────────────────────────────────
# Required: get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the default chat model (default: gpt-4.1-mini)
# OPENAI_CHAT_MODEL=gpt-4.1-mini

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Optional: override the vector store path (default: ./chroma_db)
# CHROMA_PERSIST_DIR=./chroma_db

# ── HuggingFace ──────────────────────────────────────────────────────────────
# Optional: custom cache directory for embedding/reranker models (~3.4 GB total)
# HF_HOME=/path/to/hf_cache
